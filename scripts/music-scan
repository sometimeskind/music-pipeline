#!/usr/bin/env bash
set -euo pipefail

SPOTDL_DIR=~/Music/inbox/spotdl
QUARANTINE=~/Music/quarantine
PLAYLISTS=~/Music/playlists
START_TIME=$(date +%s)

log() { echo "[$(date -Iseconds)] $*"; }

push_metrics() {
    [[ -z "${PUSHGATEWAY_URL:-}" ]] && return 0
    local body=$1
    printf '%s\n' "$body" \
        | curl -sf --data-binary @- "${PUSHGATEWAY_URL}/metrics/job/music_scan" || true
}

FAILURE_REASON=""
QUARANTINED_BEFORE=0
QUARANTINED_AFTER=0

finish() {
    local exit_code=$1
    local end_time duration success
    end_time=$(date +%s)
    duration=$((end_time - START_TIME))

    if [[ $exit_code -eq 0 ]]; then
        success=1
        FAILURE_REASON=""
    else
        success=0
    fi

    local quarantined=$(( QUARANTINED_AFTER - QUARANTINED_BEFORE ))
    [[ $quarantined -lt 0 ]] && quarantined=0

    local navidrome_success=${NAVIDROME_RESCAN_SUCCESS:-1}

    local body="# TYPE music_scan_last_run_success gauge
music_scan_last_run_success ${success}
# TYPE music_scan_duration_seconds gauge
music_scan_duration_seconds ${duration}
# TYPE music_scan_quarantined_tracks_total gauge
music_scan_quarantined_tracks_total ${quarantined}
# TYPE music_scan_navidrome_rescan_success gauge
music_scan_navidrome_rescan_success ${navidrome_success}"

    if [[ $success -eq 0 ]]; then
        body+="
# TYPE music_scan_last_failure_reason gauge
music_scan_last_failure_reason{reason=\"${FAILURE_REASON}\"} 1"
    fi

    push_metrics "$body"
}

handle_sigterm() {
    log "Shutdown signal received — exiting"
    FAILURE_REASON=interrupted
    [[ -n "${BEET_PID:-}" ]] && kill "$BEET_PID" 2>/dev/null || true
    exit 130
}
trap handle_sigterm SIGTERM
trap 'finish $?' EXIT

navidrome_rescan() {
    NAVIDROME_RESCAN_SUCCESS=1
    [[ -z "${NAVIDROME_URL:-}" || -z "${NAVIDROME_API_KEY:-}" ]] && return 0
    local user password
    IFS=: read -r user password <<< "$NAVIDROME_API_KEY"
    log "Triggering Navidrome library rescan..."
    local response
    response=$(curl -sf \
        "${NAVIDROME_URL}/rest/startScan?u=${user}&p=${password}&v=1.16.1&c=music-pipeline&f=json" \
        2>&1) || {
        log "WARNING: Navidrome rescan request failed"
        NAVIDROME_RESCAN_SUCCESS=0
        return 0
    }
    local status
    status=$(echo "$response" | jq -r '."subsonic-response".status' 2>/dev/null || echo "unknown")
    if [[ "$status" == "ok" ]]; then
        log "    Navidrome rescan triggered successfully."
    else
        log "WARNING: Navidrome rescan returned unexpected status: $status"
        log "    Response: $response"
        NAVIDROME_RESCAN_SUCCESS=0
    fi
}

log "==> music-scan starting"

QUARANTINED_BEFORE=$(find "$QUARANTINE" -type f 2>/dev/null | wc -l || echo 0)

log "==> Importing from inbox..."
beet import --quiet ~/Music/inbox &
BEET_PID=$!
wait $BEET_PID
BEET_PID=""

log "==> Refreshing library metadata..."
beet update 2>&1 || true

log "==> Regenerating playlists..."
mkdir -p "$PLAYLISTS"
for spotdl_file in "$SPOTDL_DIR"/*.spotdl; do
    [[ -e "$spotdl_file" ]] || continue
    name=$(basename "$spotdl_file" .spotdl)
    log "    Generating: $PLAYLISTS/$name.m3u"
    beet ls -f '$path' source:"$name" \
        | while IFS= read -r p; do
            realpath --relative-to="$(realpath "$PLAYLISTS")" "$p"
          done \
        > "$PLAYLISTS/$name.m3u"
done

QUARANTINED_AFTER=$(find "$QUARANTINE" -type f 2>/dev/null | wc -l || echo 0)

navidrome_rescan

log "==> music-scan complete"

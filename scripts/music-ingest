#!/usr/bin/env bash
set -euo pipefail

SPOTDL_DIR=~/Music/inbox/spotdl
QUARANTINE=~/Music/quarantine
PLAYLISTS=~/Music/playlists
COOKIE_FILE=~/.config/spotdl/cookies.txt

if [[ ! -f "$COOKIE_FILE" ]]; then
    echo "Error: YouTube Premium cookies not found at $COOKIE_FILE" >&2
    echo "See README for export instructions." >&2
    exit 1
fi

if [[ -z "${SPOTIFY_CLIENT_ID:-}" || -z "${SPOTIFY_CLIENT_SECRET:-}" ]]; then
    echo "Error: SPOTIFY_CLIENT_ID and SPOTIFY_CLIENT_SECRET must be set" >&2
    exit 1
fi

SPOTDL_OPTS=(
    --cookie-file "$COOKIE_FILE"
    --client-id "$SPOTIFY_CLIENT_ID"
    --client-secret "$SPOTIFY_CLIENT_SECRET"
)

audio_files_in() {
    find "$1" -maxdepth "${2:-1}" -type f | grep -Ei "\.(mp3|flac|ogg|opus|m4a|aac|wav|wma|aiff|ape|mpc)$" || true
}

# Remove beets source tags for tracks that were removed from a Spotify playlist.
# Compares the .spotdl snapshot taken before sync to the updated file after sync.
# Files are never deleted — only the source association is cleared.
remove_stale_source_tags() {
    local name=$1 spotdl_file=$2 before_snapshot=$3

    local before_urls after_urls removed_urls
    before_urls=$(jq -r '.[].url' "$before_snapshot" 2>/dev/null | sort || true)
    after_urls=$(jq  -r '.[].url' "$spotdl_file"     2>/dev/null | sort || true)

    [[ -z "$before_urls" ]] && return

    removed_urls=$(comm -23 <(echo "$before_urls") <(echo "$after_urls") || true)
    [[ -z "$removed_urls" ]] && return

    echo "==> Unlinking removed tracks from playlist: $name"
    while IFS= read -r url; do
        [[ -z "$url" ]] && continue
        local track_name first_artist
        track_name=$(jq -r --arg u "$url" '.[] | select(.url == $u) | .name'        "$before_snapshot")
        first_artist=$(jq -r --arg u "$url" '.[] | select(.url == $u) | .artists[0]' "$before_snapshot")

        echo "  Unlinking: $track_name — $first_artist"
        if beet ls "title:$track_name" "artist:$first_artist" "source:$name" 2>/dev/null | grep -q .; then
            beet modify -y "title:$track_name" "artist:$first_artist" "source:$name" source=
        else
            echo "  WARNING: not found in beets — may need manual cleanup: $track_name by $first_artist" >&2
        fi
    done <<< "$removed_urls"
}

for spotdl_file in "$SPOTDL_DIR"/*.spotdl; do
    [[ -e "$spotdl_file" ]] || { echo "No .spotdl files found in $SPOTDL_DIR" >&2; exit 1; }
    name=$(basename "$spotdl_file" .spotdl)
    echo "==> Syncing playlist: $name"
    mkdir -p "$SPOTDL_DIR/$name"

    before_snapshot=$(mktemp)
    cp "$spotdl_file" "$before_snapshot"

    spotdl "${SPOTDL_OPTS[@]}" sync "$spotdl_file" --output "$SPOTDL_DIR/$name" --sync-without-deleting

    remove_stale_source_tags "$name" "$spotdl_file" "$before_snapshot"
    rm -f "$before_snapshot"

    echo "==> Importing $name into beets..."
    beet import --quiet --set source="$name" "$SPOTDL_DIR/$name" || true

    echo "==> Generating playlist: $PLAYLISTS/$name.m3u"
    mkdir -p "$PLAYLISTS"
    beet ls -f '$path' source:"$name" \
        | while IFS= read -r p; do
            realpath --relative-to="$(realpath "$PLAYLISTS")" "$p"
          done \
        > "$PLAYLISTS/$name.m3u"

    echo "==> Quarantining skipped files from $name..."
    audio_files_in "$SPOTDL_DIR/$name" 10 | while read -r f; do
        mv "$f" "$QUARANTINE/"
    done
done

echo ""
echo "==> Processing inbox..."
music-import

echo ""
echo "==> Refreshing library metadata..."
beet update 2>&1 || true

#!/usr/bin/env bash
set -euo pipefail

SPOTDL_DIR=~/Music/inbox/spotdl
COOKIE_FILE=~/.config/spotdl/cookies.txt
START_TIME=$(date +%s)

log() { echo "[$(date -Iseconds)] $*"; }

push_metrics() {
    [[ -z "${PUSHGATEWAY_URL:-}" ]] && return 0
    local body=$1
    printf '%s\n' "$body" \
        | curl -sf --data-binary @- "${PUSHGATEWAY_URL}/metrics/job/music_ingest" || true
}

FAILURE_REASON=""
PLAYLISTS_TOTAL=0
PLAYLISTS_SKIPPED=0

finish() {
    local exit_code=$1
    local end_time duration success
    end_time=$(date +%s)
    duration=$((end_time - START_TIME))
    success=$([[ $exit_code -eq 0 ]] && echo 1 || echo 0)

    push_metrics "# TYPE music_ingest_last_run_success gauge
music_ingest_last_run_success ${success}
# TYPE music_ingest_duration_seconds gauge
music_ingest_duration_seconds ${duration}
# TYPE music_ingest_playlists_total gauge
music_ingest_playlists_total ${PLAYLISTS_TOTAL}
# TYPE music_ingest_playlists_skipped_total gauge
music_ingest_playlists_skipped_total ${PLAYLISTS_SKIPPED}
# TYPE music_ingest_last_failure_reason gauge
music_ingest_last_failure_reason{reason=\"${FAILURE_REASON}\"} $((1 - success))"
}

handle_sigterm() {
    log "Shutdown signal received — pushing interrupted metrics and exiting"
    FAILURE_REASON=interrupted
    finish 1
    [[ -n "${SPOTDL_PID:-}" ]] && kill "$SPOTDL_PID" 2>/dev/null || true
    exit 130
}
trap handle_sigterm SIGTERM

# Classify a spotdl stderr capture into a failure reason string.
classify_failure() {
    local stderr_output=$1
    if echo "$stderr_output" | grep -qiE "SpotifyError|Invalid credentials"; then
        echo "auth_spotify"
    elif echo "$stderr_output" | grep -qiE "HTTP Error 403|Sign in to confirm|cookies"; then
        echo "auth_youtube"
    elif echo "$stderr_output" | grep -qiE "429|Too Many Requests"; then
        echo "rate_limited"
    else
        echo "spotdl_error"
    fi
}

# --- Pre-flight checks ---

if [[ ! -f "$COOKIE_FILE" ]]; then
    log "Error: YouTube Premium cookies not found at $COOKIE_FILE"
    log "See README for export instructions."
    FAILURE_REASON=missing_cookies
    finish 1
    exit 1
fi

if [[ -z "${SPOTIFY_CLIENT_ID:-}" || -z "${SPOTIFY_CLIENT_SECRET:-}" ]]; then
    log "Error: SPOTIFY_CLIENT_ID and SPOTIFY_CLIENT_SECRET must be set"
    FAILURE_REASON=auth_spotify
    finish 1
    exit 1
fi

available_kb=$(df -k ~/Music | awk 'NR==2 {print $4}')
if [[ "$available_kb" -lt 1048576 ]]; then
    log "Error: less than 1 GB free on ~/Music (${available_kb} KB available)"
    FAILURE_REASON=disk_full
    finish 1
    exit 1
fi

# --- Jitter ---

if [[ -n "${SYNC_JITTER_SECONDS:-}" && "$SYNC_JITTER_SECONDS" -gt 0 ]]; then
    sleep $(( RANDOM % SYNC_JITTER_SECONDS ))
fi

# --- spotdl sync loop ---

SPOTDL_OPTS=(
    --cookie-file "$COOKIE_FILE"
    --client-id "$SPOTIFY_CLIENT_ID"
    --client-secret "$SPOTIFY_CLIENT_SECRET"
)

log "==> music-ingest starting"

found_any=false
for spotdl_file in "$SPOTDL_DIR"/*.spotdl; do
    [[ -e "$spotdl_file" ]] || { log "No .spotdl files found in $SPOTDL_DIR"; break; }
    found_any=true
    name=$(basename "$spotdl_file" .spotdl)

    # .nosync support — skip spotdl sync for frozen playlists
    if [[ -f "${spotdl_file%.spotdl}.nosync" ]]; then
        log "==> Skipping sync for static playlist: $name (.nosync present)"
        PLAYLISTS_SKIPPED=$(( PLAYLISTS_SKIPPED + 1 ))
        PLAYLISTS_TOTAL=$(( PLAYLISTS_TOTAL + 1 ))
        continue
    fi

    # Validate .spotdl file before syncing
    if ! jq empty "$spotdl_file" 2>/dev/null; then
        log "WARNING: $spotdl_file is not valid JSON — skipping"
        PLAYLISTS_TOTAL=$(( PLAYLISTS_TOTAL + 1 ))
        continue
    fi

    log "==> Syncing playlist: $name"
    PLAYLISTS_TOTAL=$(( PLAYLISTS_TOTAL + 1 ))
    mkdir -p "$SPOTDL_DIR/$name"

    before_snapshot=$(mktemp)
    cp "$spotdl_file" "$before_snapshot"

    stderr_tmp=$(mktemp)
    if spotdl "${SPOTDL_OPTS[@]}" sync "$spotdl_file" --output "$SPOTDL_DIR/$name" --sync-without-deleting \
            2> "$stderr_tmp" &
    then
        SPOTDL_PID=$!
        wait $SPOTDL_PID || {
            sync_exit=$?
            SPOTDL_PID=""
            FAILURE_REASON=$(classify_failure "$(cat "$stderr_tmp")")
            log "ERROR: spotdl sync failed for $name (exit $sync_exit, reason=$FAILURE_REASON)"
            cat "$stderr_tmp" >&2
            rm -f "$before_snapshot" "$stderr_tmp"
            finish $sync_exit
            exit $sync_exit
        }
        SPOTDL_PID=""
    fi
    rm -f "$stderr_tmp"

    # Remove beets source tags for tracks removed from this Spotify playlist.
    local_before_urls=$(jq -r '.[].url' "$before_snapshot" 2>/dev/null | sort || true)
    local_after_urls=$(jq  -r '.[].url' "$spotdl_file"     2>/dev/null | sort || true)
    if [[ -n "$local_before_urls" ]]; then
        removed_urls=$(comm -23 <(echo "$local_before_urls") <(echo "$local_after_urls") || true)
        if [[ -n "$removed_urls" ]]; then
            log "==> Unlinking removed tracks from playlist: $name"
            while IFS= read -r url; do
                [[ -z "$url" ]] && continue
                track_name=$(jq -r --arg u "$url" '.[] | select(.url == $u) | .name'        "$before_snapshot")
                first_artist=$(jq -r --arg u "$url" '.[] | select(.url == $u) | .artists[0]' "$before_snapshot")
                log "  Unlinking: $track_name — $first_artist"
                if beet ls "title:$track_name" "artist:$first_artist" "source:$name" 2>/dev/null | grep -q .; then
                    beet modify -y "title:$track_name" "artist:$first_artist" "source:$name" source=
                else
                    log "  WARNING: not found in beets — may need manual cleanup: $track_name by $first_artist"
                fi
            done <<< "$removed_urls"
        fi
    fi
    rm -f "$before_snapshot"

    sleep 5
done

log "==> Sync complete. Calling music-scan for local import and playlist generation..."
music-scan

finish 0
log "==> music-ingest complete"

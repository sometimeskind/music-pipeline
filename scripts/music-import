#!/usr/bin/env bash
set -euo pipefail

INBOX=~/Music/inbox
QUARANTINE=~/Music/quarantine

log() { echo "[$(date -Iseconds)] $*"; }

handle_sigterm() {
    log "Shutdown signal received"
    [[ -n "${BEET_PID:-}" ]] && kill "$BEET_PID" 2>/dev/null || true
    exit 130
}
trap handle_sigterm SIGTERM

audio_files_in() {
    find "$1" -maxdepth "${2:-1}" -type f | grep -Ei "\.(mp3|flac|ogg|opus|m4a|aac|wav|wma|aiff|ape|mpc)$" || true
}

pre_q=$(find "$QUARANTINE" -type f | wc -l)

log "==> Importing from inbox..."
beet import --quiet "$INBOX" &
BEET_PID=$!
wait $BEET_PID
BEET_PID=""

log "==> Quarantining skipped files..."
audio_files_in "$INBOX" 1 | while read -r f; do
    mv "$f" "$QUARANTINE/"
done

post_q=$(find "$QUARANTINE" -type f | wc -l)
quarantined=$((post_q - pre_q))

log "Quarantined : $quarantined file(s) → $QUARANTINE"
log "Log         : ~/.config/beets/import.log"

#!/usr/bin/env bash
# Provision playlists from config/playlists.conf onto the PVC.
# Reads the playlist registry and calls music-setup for each entry.
# Idempotent: skips playlists whose .spotdl file already exists.
#
# Usage: music-provision [/path/to/playlists.conf]
# Default config path: /root/.config/music-pipeline/playlists.conf
set -euo pipefail

CONF="${1:-/root/.config/music-pipeline/playlists.conf}"

if [[ ! -f "$CONF" ]]; then
    echo "Error: playlist config not found at $CONF" >&2
    echo "Mount config/playlists.conf to that path, or pass it as an argument." >&2
    exit 1
fi

provisioned=0
skipped=0

while IFS= read -r line; do
    # Strip comments and blank lines
    line="${line%%#*}"
    line="${line//[$'\t' ]/ }"
    line="$(echo "$line" | tr -s ' ' | sed 's/^ //;s/ $//')"
    [[ -z "$line" ]] && continue

    name="${line%% *}"
    url="${line#* }"

    if [[ -z "$name" || -z "$url" || "$name" == "$url" ]]; then
        echo "WARNING: malformed line in $CONF — skipping: $line" >&2
        continue
    fi

    echo "==> Provisioning: $name"
    music-setup --name "$name" --url "$url"
    provisioned=$(( provisioned + 1 ))
done < "$CONF"

echo ""
echo "Provisioning complete: $provisioned playlist(s) processed."
